# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Xendit Configuration
XENDIT_SECRET_KEY=xendit_secret_key_here
XENDIT_PUBLIC_KEY=xendit_public_key_here
XENDIT_WEBHOOK_TOKEN=your-webhook-token

# Application Configuration
APP_NAME=Xenitide API
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-production-domain.com"]

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Database URL (if using direct database connection)
# DATABASE_URL=postgresql://user:password@localhost:5432/xenitide

# Redis Configuration (for caching)
# REDIS_URL=redis://localhost:6379

# Email Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# AI Configuration (OpenAI)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-3.5-turbo

# Monitoring
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
